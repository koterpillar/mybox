#!/usr/bin/env bash
# Install dependencies required for the project

set -euo pipefail

OPT_LINT="true"
OPT_HASKELL="true"
while [ $# -gt 0 ]; do
  case "$1" in
    --no-lint)
      OPT_LINT=""
      shift
      ;;
    --no-haskell)
      OPT_HASKELL=""
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

command_exists() {
  type -f "$1" >/dev/null 2>&1
}

sudo_() {
  if [ "$(id -u)" -eq 0 ]
  then
    "$@"
  else
    sudo "$@"
  fi
}

case "$OSTYPE" in
  darwin*)
    if ! command_exists brew
    then
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    if [ -d /opt/homebrew ]
    then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    fi

    if [ -n "${OPT_LINT-}" ] && ! command_exists shellcheck
    then
      brew install shellcheck
    fi
    if ! command_exists tmux
    then
      brew install tmux
    fi
  ;;
  linux*)
    DISTRO=$(grep '^ID=' /etc/os-release | cut -d = -f 2)
    case $DISTRO in
      debian|ubuntu)
        if [ -n "${CI-}" ]
        then
          sudo_ apt update
        fi
        sudo_ apt install --yes liblzma-dev libbz2-dev
        if ! command_exists tmux
        then
          sudo_ apt install --yes tmux
        fi
        ;;
      fedora)
        sudo_ dnf install --assumeyes xz-devel bzip2-devel
        if ! command_exists tmux
        then
          sudo_ dnf install --assumeyes tmux
        fi
    esac
  ;;
esac

GH_CURL=(curl -fsSL --retry 5)
if [ -n "${GITHUB_TOKEN-}" ]
then
  GH_CURL+=(--header "authorization: Bearer $GITHUB_TOKEN")
elif command_exists gh && gh auth status >/dev/null 2>&1
then
  GH_CURL+=(--header "authorization: Bearer $(gh auth token)")
fi

if [ -n "${OPT_LINT-}" ] && [ -n "${OPT_HASKELL-}" ] && ! command_exists fourmolu
then
  OS=$(echo "$OSTYPE" | sed -E 's/darwin.+/darwin/;s/linux.+/linux/')
  ARCH=$(uname -m | sed 's/aarch64/arm64/')

  FILENAME=$(
    "${GH_CURL[@]}" "https://api.github.com/repos/fourmolu/fourmolu/releases/latest" | \
    python3 -c 'import sys,json;[print(a["name"]) for a in json.load(sys.stdin)["assets"]]' | \
    grep "${OS}-${ARCH}"
  )

  if [ -z "$FILENAME" ]
  then
    echo "Error: no fourmolu binary for ${OS}-${ARCH}" >&2
    exit 1
  fi

  mkdir -p ~/.local/bin
  FOURMOLU_URL="https://github.com/fourmolu/fourmolu/releases/latest/download/${FILENAME}"
  FOURMOLU_DOWNLOAD="$(mktemp)"
  FOURMOLU_EXTRACT_DIR="$(mktemp -d)"
  cleanup_fourmolu() {
    rm -f "$FOURMOLU_DOWNLOAD"
    rm -rf "$FOURMOLU_EXTRACT_DIR"
  }
  trap cleanup_fourmolu EXIT
  "${GH_CURL[@]}" "$FOURMOLU_URL" -o "$FOURMOLU_DOWNLOAD"
  unzip -q "$FOURMOLU_DOWNLOAD" -d "$FOURMOLU_EXTRACT_DIR"

  FOURMOLU_PATH=$(find "$FOURMOLU_EXTRACT_DIR" -type f -name fourmolu | head -n 1)
  if [ -z "$FOURMOLU_PATH" ]
  then
    echo "Error: could not find fourmolu in zip archive" >&2
    exit 1
  fi
  chmod +x "$FOURMOLU_PATH"
  mv "$FOURMOLU_PATH" ~/.local/bin/fourmolu
fi
